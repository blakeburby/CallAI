<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.blake.callai.local-bridge</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/blakeburby/CallAI-local-bridge &amp;&amp; mkdir -p logs &amp;&amp; npm run local-bridge</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/blakeburby/CallAI-local-bridge</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/blakeburby/CallAI-local-bridge/logs/local-bridge.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/blakeburby/CallAI-local-bridge/logs/local-bridge.err.log</string>
</dict>
</plist>

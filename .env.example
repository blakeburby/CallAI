OPENAI_API_KEY=        # required for OpenAI summaries and task parsing
API_SECRET_KEY=        # required - shared secret for Vapi tool/admin endpoints
FRONTEND_PASSCODE=     # required for browser operator console login

VAPI_API_KEY=          # required for outbound calls
VAPI_PUBLIC_KEY=       # required for browser voice frontend
VAPI_ASSISTANT_ID=     # required for browser and phone calls
VAPI_ASSISTANT_NAME=CallAI Developer Operator
VAPI_PHONE_NUMBER_ID=  # required for outbound calls
VAPI_WEBHOOK_SECRET=   # optional Vapi webhook shared secret

DATABASE_URL=          # required for Railway Postgres production persistence
DATABASE_SSL=auto      # auto, true/require, or false/disable
DATABASE_POOL_MAX=10

DEFAULT_REPO_OWNER=blakeburby
DEFAULT_REPO_NAME=CallAI
DEFAULT_REPO_URL=https://github.com/blakeburby/CallAI.git
DEFAULT_REPO_PATH=/Users/blakeburby/Desktop/CallAI-main
DEFAULT_REPO_BRANCH=main
DEFAULT_REPO_ALIASES=callai,main repo,current repo,this repo
DEFAULT_CODEX_CLOUD_ENV_ID=

CODEX_EXECUTABLE=codex
CODEX_EXECUTION_MODE=local
RUNNER_ID=local-runner
RUNNER_POLL_INTERVAL_MS=5000
RUNNER_TEST_TIMEOUT_MS=180000
CHAT_WEBHOOK_URL=

TASK_PARSER_MODEL=gpt-4o-mini
VOICE_SUMMARY_MODEL=gpt-4o
INTENT_MODEL=gpt-4o-mini
PORT=3000

API_SECRET_KEY=        # required - shared secret for Vapi tool/admin endpoints
FRONTEND_PASSCODE=     # required for browser operator console login

VAPI_API_KEY=          # required for outbound calls
VAPI_PUBLIC_KEY=       # required for browser voice frontend
VAPI_ASSISTANT_ID=     # required for browser and phone calls
VAPI_ASSISTANT_NAME=CallAI Developer Operator
VAPI_PHONE_NUMBER_ID=  # required for outbound calls
VAPI_WEBHOOK_SECRET=   # optional Vapi webhook shared secret

DATABASE_URL=          # required for Railway Postgres production persistence
DATABASE_SSL=auto      # auto, true/require, or false/disable
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=15000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_MAX_USES=500

DEFAULT_REPO_OWNER=blakeburby
DEFAULT_REPO_NAME=CallAI
DEFAULT_REPO_URL=https://github.com/blakeburby/CallAI.git
DEFAULT_REPO_PATH=/Users/blakeburby/Developer/CallAI-main
DEFAULT_REPO_BRANCH=codex/callai-terminal-ops-last-mile
DEFAULT_REPO_ALIASES=callai,main repo,current repo,this repo
DEFAULT_CODEX_CLOUD_ENV_ID=

CODEX_EXECUTABLE=codex
CODEX_EXECUTION_MODE=local
CODEX_THREAD_BRIDGE_ENABLED=false
CODEX_THREAD_LABEL=CallAI Codex thread
CODEX_THREAD_STALE_AFTER_MS=900000
JARVIS_CODEX_CHAT_ENABLED=true
JARVIS_CODEX_CHAT_TIMEOUT_MS=60000
JARVIS_CODEX_CHAT_HISTORY_LIMIT=16
RUNNER_ID=local-runner
RUNNER_TASK_SCOPE=all        # all, read_only, or write
RUNNER_POLL_INTERVAL_MS=5000
RUNNER_TEST_TIMEOUT_MS=180000
RUNNER_DISABLE_HEALTH_SERVER=false
RUNNER_HEALTH_PORT=

LOCAL_BRIDGE_RUNNER_ID=macbook-local-bridge
LOCAL_BRIDGE_CODEX_EXECUTABLE=/Applications/Codex.app/Contents/Resources/codex
LOCAL_BRIDGE_REPO_PATH=/Users/blakeburby/Developer/CallAI-main
LOCAL_BRIDGE_TASK_SCOPE=all  # set Railway runner to read_only if this Mac bridge handles writes
DESKTOP_MAX_STEPS=8
DESKTOP_STEP_TIMEOUT_MS=15000
DESKTOP_NAVIGATION_WAIT_MS=1800
DESKTOP_REQUIRE_CHROME_JS_EVENTS=true
DESKTOP_FAST_AUTONOMY=true
DESKTOP_CAPTURE_SCREENSHOTS=true
RUNNER_ENABLE_FULL_COMPUTER_CONTROL=false
COMPUTER_CONTROL_MAX_STEPS=6
COMPUTER_CONTROL_SHELL_TIMEOUT_MS=20000
COMPUTER_CONTROL_STEP_TIMEOUT_MS=15000
COMPUTER_CONTROL_CONFIRM_RISKY=true
COMPUTER_CONTROL_CAPTURE_SCREENSHOTS=true

TWILIO_ACCOUNT_SID=          # optional for SMS control
TWILIO_AUTH_TOKEN=           # optional for SMS control
TWILIO_FROM_NUMBER=          # optional, Twilio SMS-capable phone number
OWNER_PHONE_NUMBER=+19712670353
SMS_WEBHOOK_SECRET=          # optional but recommended for /sms/inbound

CHAT_WEBHOOK_URL=

PORT=3000

{
  "name": "callai",
  "version": "1.0.0",
  "description": "Remote voice-controlled developer operator for Vapi, Codex, and repo workflows.",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "frontend:dev": "vite --host 0.0.0.0",
    "frontend:build": "vite build",
    "backend:build": "tsup src/server.ts src/runner/agentRunner.ts src/runner/localBridge.ts --format esm",
    "build": "npm run frontend:build && npm run backend:build",
    "db:migrate": "tsx src/scripts/migrateDatabase.ts",
    "db:seed": "tsx src/scripts/seedDatabase.ts",
    "start": "node dist/server.js",
    "runner": "node dist/runner/agentRunner.js",
    "runner:dev": "tsx src/runner/agentRunner.ts",
    "local-bridge": "node dist/runner/localBridge.js",
    "local-bridge:dev": "tsx src/runner/localBridge.ts"
  },
  "dependencies": {
    "@openai/codex": "^0.122.0",
    "@vapi-ai/web": "^2.5.2",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "openai": "^6.10.0",
    "pg": "^8.20.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.9"
  }
}
